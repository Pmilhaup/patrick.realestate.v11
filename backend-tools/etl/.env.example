# Copy this file to `.env` (same folder) and fill in real values.
# Never commit `.env` — it contains the service-role key.

SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_KEY=<service-role JWT — see backend.html for the live value>

# Optional. Without a token Socrata still works but throttles harder
# (~1 req/sec per IP). Free signup at https://datacatalog.cookcountyil.gov/
SOCRATA_APP_TOKEN=
